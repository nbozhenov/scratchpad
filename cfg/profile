# Ensure that /tmp is on a temporary file system.
# (the assumption is that if it is mounted at least somewhere, probably it is on
# a temporary file system).
if ! mount | grep -q '\s/tmp'; then
  echo "error: /tmp is not mounted on a temporary filesystem" >&2
else

  # Hide Python cache to temporary directory.
  export PYTHONPYCACHEPREFIX=/tmp/__pycache__

fi
